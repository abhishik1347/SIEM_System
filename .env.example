# Copy this file to .env and edit values.
# NOTE: .env is sourced by bash in scripts/run_siem.sh, so keep it shell-compatible: KEY=value

# Flask API
SIEM_SERVER_HOST=0.0.0.0
SIEM_SERVER_PORT=5000
SIEM_FLASK_DEBUG=0
SIEM_MAX_CONTENT_LENGTH=2097152

# API keys accepted by the ingest server (comma-separated)
SIEM_VALID_API_KEYS=agent123

# Streamlit dashboard
SIEM_DASH_HOST=0.0.0.0
SIEM_DASH_PORT=8501

# Agent (set on the Windows machine that runs the agent)
# SIEM_API_URL=http://<VM_PUBLIC_IP>:5000/ingest
# SIEM_API_KEY=agent123
